# Database
POSTGRES_USER=sdr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sdrdb
DATABASE_URL=postgresql+asyncpg://sdr:changeme@postgres:5432/sdrdb

# Redis
REDIS_URL=redis://redis:6379/0

# SDR Device
RTL_SDR_DEVICE_INDEX=0
RTL_SDR_GAIN=auto

# Optional external APIs (for radio metadata)
LASTFM_API_KEY=
MUSICBRAINZ_USER_AGENT=rtl-sdr-dashboard/1.0

# Audio
HLS_OUTPUT_DIR=/tmp/hls
